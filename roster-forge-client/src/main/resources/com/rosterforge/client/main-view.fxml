<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rosterforge.client.controller.MainController">

    <top>
        <Label text="RosterForge" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-padding: 12 16 12 16;"/>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- ══════════════ EMPLOYEES ══════════════ -->
            <Tab text="Employees">
                <content>
                    <VBox spacing="10">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <TextField fx:id="empNameField" promptText="Full name" prefWidth="160"/>
                            <CheckBox fx:id="empRoleShiftManager" text="Shift Manager"/>
                            <CheckBox fx:id="empRoleSoc"          text="SOC"/>
                            <CheckBox fx:id="empRoleSecurity"     text="Security"/>
                            <Label text="Max shifts/week:"/>
                            <TextField fx:id="empMaxShiftsField" prefWidth="45"/>
                            <Button text="Add"            onAction="#addEmployee"/>
                            <Button text="Update"         onAction="#updateEmployee"/>
                            <Button text="Remove"         onAction="#removeEmployee"/>
                            <Button text="Refresh"        onAction="#loadEmployees"/>
                        </HBox>

                        <Label fx:id="empStatusLabel" style="-fx-text-fill: grey;"/>

                        <TableView fx:id="empTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="empNameCol"      text="Name"       prefWidth="180"/>
                                <TableColumn fx:id="empRolesCol"     text="Roles"      prefWidth="280"/>
                                <TableColumn fx:id="empMaxShiftsCol" text="Max Shifts" prefWidth="90"/>
                            </columns>
                            <placeholder><Label text="No employees. Click Refresh or Add one."/></placeholder>
                        </TableView>
                    </VBox>
                </content>
            </Tab>

            <!-- ══════════════ SHIFTS ══════════════ -->
            <Tab text="Shifts">
                <content>
                    <VBox spacing="10">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <ComboBox fx:id="shiftDayCombo"  promptText="Day"  prefWidth="140"/>
                            <ComboBox fx:id="shiftTypeCombo" promptText="Type" prefWidth="120"/>
                            <Label text="Shift Mgr:"/>
                            <TextField fx:id="shiftMgrCount"  prefWidth="45" promptText="0"/>
                            <Label text="SOC:"/>
                            <TextField fx:id="shiftSocCount"  prefWidth="45" promptText="0"/>
                            <Label text="Security:"/>
                            <TextField fx:id="shiftSecCount"  prefWidth="45" promptText="0"/>
                            <Button text="Add"     onAction="#addShift"/>
                            <Button text="Remove"  onAction="#removeShift"/>
                            <Button text="Refresh" onAction="#loadShifts"/>
                        </HBox>

                        <Label fx:id="shiftStatusLabel" style="-fx-text-fill: grey;"/>

                        <TableView fx:id="shiftTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="shiftDayCol"   text="Day"          prefWidth="140"/>
                                <TableColumn fx:id="shiftTypeCol"  text="Type"         prefWidth="120"/>
                                <TableColumn fx:id="shiftRolesCol" text="Requirements" prefWidth="300"/>
                            </columns>
                            <placeholder><Label text="No shifts. Click Refresh or Add one."/></placeholder>
                        </TableView>
                    </VBox>
                </content>
            </Tab>

            <!-- ══════════════ PREFERENCES ══════════════ -->
            <Tab text="Preferences">
                <content>
                    <VBox spacing="10">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <ComboBox fx:id="prefEmployeeCombo" promptText="Employee" prefWidth="180"/>
                            <ComboBox fx:id="prefShiftCombo"    promptText="Shift"    prefWidth="200"/>
                            <ComboBox fx:id="prefLevelCombo"    promptText="Level"    prefWidth="130"/>
                            <Button text="Add"     onAction="#addPreference"/>
                            <Button text="Update"  onAction="#updatePreference"/>
                            <Button text="Remove"  onAction="#removePreference"/>
                            <Button text="Refresh" onAction="#loadPreferences"/>
                        </HBox>

                        <Label fx:id="prefStatusLabel" style="-fx-text-fill: grey;"/>

                        <TableView fx:id="prefTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="prefEmpCol"   text="Employee" prefWidth="180"/>
                                <TableColumn fx:id="prefShiftCol" text="Shift"    prefWidth="200"/>
                                <TableColumn fx:id="prefLevelCol" text="Level"    prefWidth="130"/>
                            </columns>
                            <placeholder><Label text="No preferences. Click Refresh or Add one."/></placeholder>
                        </TableView>
                    </VBox>
                </content>
            </Tab>

            <!-- ══════════════ ROSTER ══════════════ -->
            <Tab text="Roster">
                <content>
                    <VBox spacing="10">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Button text="Generate Roster" onAction="#generateRoster"
                                    style="-fx-font-weight: bold;"/>
                        </HBox>

                        <Label fx:id="rosterStatusLabel" style="-fx-text-fill: grey;"/>

                        <TableView fx:id="rosterTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="rosterEmpCol"   text="Employee" prefWidth="200"/>
                                <TableColumn fx:id="rosterShiftCol" text="Shift"    prefWidth="200"/>
                                <TableColumn fx:id="rosterRoleCol"  text="Role"     prefWidth="200"/>
                            </columns>
                            <placeholder><Label text="Press Generate Roster to compute assignments."/></placeholder>
                        </TableView>

                        <Label text="Violations:" style="-fx-font-weight: bold;"/>
                        <TextArea fx:id="rosterViolationsArea" editable="false" prefHeight="100"
                                  promptText="No violations."
                                  style="-fx-font-family: monospace; -fx-text-fill: #cc0000;"/>
                    </VBox>
                </content>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
